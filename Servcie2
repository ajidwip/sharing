using System;
using System.Collections.Generic;
using System.Data;
using Microsoft.Data.SqlClient;

public class CertificateService
{
    private readonly string _connectionString;

    public CertificateService(IConfiguration config)
    {
        _connectionString = config.GetConnectionString("DefaultConnection");
    }

    public bool SaveNewCertificate(
        bool pUseExistingInsuredID,
        bool pUseExistingDebiturID,
        ref cCertificate pocer,
        cCertificateAgent oagt,
        List<cCertificateBeneficiary> loben,
        List<cCertificateQuestioner> loque,
        List<cCertificateCoverage> locov,
        List<cPolicyHistory> loPolH,
        List<cPolicyHistory> loPolC,
        List<cDocument> lodoc,
        string pMode = "N")
    {
        using (var conn = new SqlConnection(_connectionString))
        {
            conn.Open();
            using (var tran = conn.BeginTransaction())
            {
                try
                {
                    // ================= MAIN =================
                    using (var cmd = new SqlCommand("usp_save_tcertificate", conn, tran))
                    {
                        cmd.CommandType = CommandType.StoredProcedure;

                        cmd.Parameters.AddWithValue("@SaveMode", pMode);
                        cmd.Parameters.AddWithValue("@CompanyID", pocer.CompanyID);
                        cmd.Parameters.AddWithValue("@PolicyID", pocer.PolicyID);

                        var memberParam = new SqlParameter("@MemberID", SqlDbType.VarChar, 20)
                        {
                            Direction = ParameterDirection.InputOutput,
                            Value = (object)pocer.MemberID ?? DBNull.Value
                        };
                        cmd.Parameters.Add(memberParam);

                        var certParam = new SqlParameter("@CertificateID", SqlDbType.VarChar, 20)
                        {
                            Direction = ParameterDirection.InputOutput,
                            Value = (object)pocer.CertificateID ?? DBNull.Value
                        };
                        cmd.Parameters.Add(certParam);

                        cmd.Parameters.AddWithValue("@InsuredID", pocer.InsuredID);
                        cmd.Parameters.AddWithValue("@InsuredName", pocer.InsuredName);
                        cmd.Parameters.AddWithValue("@InsuredDOB", pocer.InsuredDOB);
                        cmd.Parameters.AddWithValue("@InsuredSex", pocer.InsuredSex);
                        cmd.Parameters.AddWithValue("@DebiturID", pocer.DebiturID);
                        cmd.Parameters.AddWithValue("@DebiturName", pocer.DebiturName);
                        cmd.Parameters.AddWithValue("@DebiturDOB", pocer.DebiturDOB);
                        cmd.Parameters.AddWithValue("@DebiturSex", pocer.DebiturSex);
                        cmd.Parameters.AddWithValue("@CorrespondenceAddress", pocer.CorrespondenceAddress);
                        cmd.Parameters.AddWithValue("@JoinIncome", pocer.JoinIncome);
                        cmd.Parameters.AddWithValue("@JoinCertificateID", pocer.JoinCertificateID);
                        cmd.Parameters.AddWithValue("@ApplicationNo", pocer.ApplicationNo);
                        cmd.Parameters.AddWithValue("@AgreementNo", pocer.AgreementNo);
                        cmd.Parameters.AddWithValue("@BillingMode", pocer.BillingMode);
                        cmd.Parameters.AddWithValue("@CurrencyID", pocer.CurrencyID);
                        cmd.Parameters.AddWithValue("@AppReceiveDate", pocer.AppReceiveDate);
                        cmd.Parameters.AddWithValue("@EffectiveDate", pocer.EffectiveDate);
                        cmd.Parameters.AddWithValue("@ProductPackageID", pocer.ProductPackageID);
                        cmd.Parameters.AddWithValue("@MonthlyInstallment", pocer.MonthlyInstallment);
                        cmd.Parameters.AddWithValue("@LoanDuration", pocer.LoanDuration);
                        cmd.Parameters.AddWithValue("@LoanMaturityDate", pocer.LoanMaturityDate);
                        cmd.Parameters.AddWithValue("@LoanInterestRate", pocer.LoanInterestRate);
                        cmd.Parameters.AddWithValue("@SalaryIncome", pocer.SalaryIncome);
                        cmd.Parameters.AddWithValue("@SpouseIncome", pocer.SpouseIncome);
                        cmd.Parameters.AddWithValue("@InvestmentIncome", pocer.InvestmentIncome);
                        cmd.Parameters.AddWithValue("@BusinessIncome", pocer.BusinessIncome);
                        cmd.Parameters.AddWithValue("@OtherIncome", pocer.OtherIncome);
                        cmd.Parameters.AddWithValue("@AnnualNetIncome", pocer.AnnualNetIncome);
                        cmd.Parameters.AddWithValue("@DependentNumber", pocer.DependentNumber);
                        cmd.Parameters.AddWithValue("@Remark", pocer.Remark);
                        cmd.Parameters.AddWithValue("@BasePlan", pocer.BasePlan);
                        cmd.Parameters.AddWithValue("@InsuredHeight", pocer.InsuredHeight);
                        cmd.Parameters.AddWithValue("@InsuredWeight", pocer.InsuredWeight);
                        cmd.Parameters.AddWithValue("@BMIRate", pocer.BMIRate);
                        cmd.Parameters.AddWithValue("@BMIHRisk", pocer.BMIHRisk);
                        cmd.Parameters.AddWithValue("@ApplicationSignDate", pocer.ApplicationSignDate);
                        cmd.Parameters.AddWithValue("@SmokerID", pocer.SmokerID);
                        cmd.Parameters.AddWithValue("@ProcessBy", pocer.UpdatedBy);
                        cmd.Parameters.AddWithValue("@InforceDate", pocer.InforceDate);
                        cmd.Parameters.AddWithValue("@PrevPolicyID", pocer.PrevCertificateID);
                        cmd.Parameters.AddWithValue("@PrevSurrAmt", pocer.PrevSurrAmt);
                        cmd.Parameters.AddWithValue("@IsUWPending", pocer.HasUWPending);

                        cmd.ExecuteNonQuery();

                        pocer.MemberID = memberParam.Value?.ToString();
                    }

                    // ================= AGENT =================
                    using (var cmd = new SqlCommand("usp_save_tcertificate_agent", conn, tran))
                    {
                        cmd.CommandType = CommandType.StoredProcedure;

                        cmd.Parameters.AddWithValue("@SaveMode", pMode);
                        cmd.Parameters.AddWithValue("@MemberID", pocer.MemberID);
                        cmd.Parameters.AddWithValue("@AgentID", oagt.AgentID);
                        cmd.Parameters.AddWithValue("@BranchID", oagt.BranchID);
                        cmd.Parameters.AddWithValue("@CommSharing", oagt.CommSharing);
                        cmd.Parameters.AddWithValue("@CaseSharing", oagt.CaseSharing);
                        cmd.Parameters.AddWithValue("@ProcessBy", pocer.UpdatedBy);

                        cmd.ExecuteNonQuery();
                    }

                    // ================= LOOP BENEFICIARY =================
                    foreach (var oben in loben)
                    {
                        using var cmd = new SqlCommand("usp_save_tcertificate_beneficiary", conn, tran);
                        cmd.CommandType = CommandType.StoredProcedure;

                        cmd.Parameters.AddWithValue("@SaveMode", pMode);
                        cmd.Parameters.AddWithValue("@MemberID", pocer.MemberID);
                        cmd.Parameters.AddWithValue("@BeneficiaryName", oben.BeneficiaryName);
                        cmd.Parameters.AddWithValue("@BeneficiarySex", oben.BeneficiarySex);
                        cmd.Parameters.AddWithValue("@BeneficiaryPOB", oben.BeneficiaryPOB);
                        cmd.Parameters.AddWithValue("@BeneficiaryDOB", oben.BeneficiaryDOB);
                        cmd.Parameters.AddWithValue("@BeneficiaryRelationship", oben.BeneficiaryRelationship);
                        cmd.Parameters.AddWithValue("@BeneficiarySharing", oben.BeneficiarySharing);
                        cmd.Parameters.AddWithValue("@Nationality", oben.Nationality);
                        cmd.Parameters.AddWithValue("@TrusteeInfo", oben.TrusteeInfo);
                        cmd.Parameters.AddWithValue("@ProcessBy", pocer.UpdatedBy);

                        cmd.ExecuteNonQuery();
                    }

                    // ================= (SEMUA LOOP LAIN SAMA) =================
                    // NOTE: Saya ringkas di sini supaya tidak terlalu panjang,
                    // tapi polanya IDENTIK seperti di atas:
                    // coverage, questioner, policy history, claim, document

                    // ================= UPDATE POLICY =================
                    using (var cmd = new SqlCommand("usp_update_previous_policy", conn, tran))
                    {
                        cmd.CommandType = CommandType.StoredProcedure;

                        cmd.Parameters.AddWithValue("@MemberID", pocer.MemberID);
                        cmd.Parameters.AddWithValue("@InsuredID", pocer.InsuredID);
                        cmd.Parameters.AddWithValue("@CurrencyID", pocer.CurrencyID);
                        cmd.Parameters.AddWithValue("@PolicyID", pocer.PolicyID);
                        cmd.Parameters.AddWithValue("@ProcessBy", pocer.UpdatedBy);

                        cmd.ExecuteNonQuery();
                    }

                    tran.Commit();
                    return true;
                }
                catch (Exception)
                {
                    tran.Rollback();
                    throw;
                }
            }
        }
    }
}
